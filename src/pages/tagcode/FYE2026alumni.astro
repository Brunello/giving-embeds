<script type="text/javascript">
    if (!document.cookie.includes("fye_banner_closed=1")) {
        var iframe = document.createElement("iframe");
        iframe.src = "https://giving-embeds.vercel.app/FYE2026?site=alumni";
        iframe.setAttribute("id", "fye-banner");
        document.body.insertBefore(iframe, document.body.firstChild);

        window.addEventListener("message", function (event) {
            if (event.data && event.data.type === "resize") {
                var h = event.data.height + "px";
                var banner = document.getElementById("fye-banner");
                if (banner) {
                    banner.style.height = h;
                    document.documentElement.style.setProperty("--fye-banner-height", h);
                }
            }
            if (event.data === "banner closed") {
                var date = new Date(Date.now() + 86400 * 1000).toUTCString();
                var banner = document.getElementById("fye-banner");
                banner.parentNode.removeChild(banner);
                document.cookie =
                    "fye_banner_closed=1; expires=" + date + "; max-age=86400;";
            }
        });
    }
</script>
<style>
    /*
      Alumni theme: the banner iframe stays in normal flow (NOT position:fixed)
      so it naturally pushes the page down. The sticky .header-wrapper still
      needs its top offset by the banner height, matching the proven alumni
      tag code. Magazine/giving use a fixed-overlay approach instead.
    */
    #fye-banner {
        width: 100%;
        height: 0;
        border: 0;
    }
    body:not(.back-to-top-shown) .header-wrapper {
        top: var(--fye-banner-height, 0px) !important;
    }
</style>
