<script type="text/javascript">
    function getCookie(name) {
        var parts = document.cookie.split(name + "=");
        if (parts.length === 2) return parts.pop().split(";").shift();
    }

    window.addEventListener("load", function () {
        if (!document.cookie.includes("pages_visited")) {
            document.cookie =
                "pages_visited=1; expires=" +
                new Date(Date.now() + 86400 * 1000).toUTCString();
        } else if (document.cookie.includes("pages_visited=1")) {
            var pages_visited = getCookie("pages_visited");
            document.cookie =
                "pages_visited=" +
                (parseInt(pages_visited) + 1) +
                "; expires=" +
                new Date(Date.now() + 86400 * 1000).toUTCString();
        }
    });

    if (
        !document.cookie.includes("survey_popup_closed=1") &&
        parseInt(getCookie("pages_visited")) >= 2
    ) {
        var iframe = document.createElement("iframe");
        iframe.src = "https://giving-embeds.vercel.app/surveypopup";
        iframe.setAttribute("id", "survey-popup");
        document.body.appendChild(iframe);

        window.addEventListener("message", function (event) {
            if (event.data === "popup closed") {
                var date = new Date(Date.now() + 86400 * 1000).toUTCString();
                document.getElementById("survey-popup").style.display = "none";
                document.cookie =
                    "survey_popup_closed=1; expires=" + date + "; max-age=86400;";
            }
        });
    }
</script>
<style>
    #survey-popup {
        width: 100vw;
        height: 100vh;
        border: 0;
        position: fixed;
        top: 0;
        left: 0;
        z-index: 1000;
    }
</style>
