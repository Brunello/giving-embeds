<script type="text/javascript">
    if (!document.cookie.includes("survey_banner_closed=1")) {
        var iframe = document.createElement("iframe");
        iframe.src = "https://giving-embeds.vercel.app/surveybanner?site=alumni";
        iframe.setAttribute("id", "survey-banner");
        document.body.insertBefore(iframe, document.body.firstChild);

        window.addEventListener("message", function (event) {
            if (event.data && event.data.type === "resize") {
                var h = event.data.height + "px";
                var banner = document.getElementById("survey-banner");
                if (banner) {
                    banner.style.height = h;
                    document.documentElement.style.setProperty("--survey-banner-height", h);
                }
            }
            if (event.data === "banner closed") {
                var date = new Date(Date.now() + 86400 * 1000).toUTCString();
                var banner = document.getElementById("survey-banner");
                banner.parentNode.removeChild(banner);
                document.cookie =
                    "survey_banner_closed=1; expires=" + date + "; max-age=86400;";
            }
        });
    }
</script>
<style>
    #survey-banner {
        width: 100%;
        height: 0;
        border: 0;
        position: fixed;
        top: 0;
        z-index: 101;
    }
    body:has(#survey-banner) .header-wrapper {
        top: var(--survey-banner-height, 0px);
    }
</style>
