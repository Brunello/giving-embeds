<script type="text/javascript">
    if (!document.cookie.includes("fye_banner_closed=1")) {
        var iframe = document.createElement("iframe");
        iframe.src = "https://giving-embeds.vercel.app/FYE2026?site=giving";
        iframe.setAttribute("id", "fye-banner");
        document.body.insertBefore(iframe, document.body.firstChild);

        window.addEventListener("message", function (event) {
            if (event.data && event.data.type === "resize") {
                var h = event.data.height + "px";
                var banner = document.getElementById("fye-banner");
                if (banner) {
                    banner.style.height = h;
                    document.documentElement.style.setProperty("--fye-banner-height", h);
                }
            }
            if (event.data === "banner closed") {
                var date = new Date(Date.now() + 86400 * 1000).toUTCString();
                var banner = document.getElementById("fye-banner");
                banner.parentNode.removeChild(banner);
                document.cookie =
                    "fye_banner_closed=1; expires=" + date + "; max-age=86400;";
            }
        });
    }
</script>
<style>
    #fye-banner {
        width: 100%;
        height: 0;
        border: 0;
        position: fixed;
        top: 0;
        z-index: 101;
    }
    body:has(#fye-banner) .site-header {
        top: var(--fye-banner-height, 0px);
    }
    body:has(#fye-banner) .dialog-off-canvas-main-canvas {
        padding-top: var(--fye-banner-height, 0px);
    }
    body:has(#fye-banner) #main-wrapper {
        margin-top: var(--fye-banner-height, 0px);
    }
</style>
