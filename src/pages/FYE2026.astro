---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Fiscal Year End 2026 Banner">
    <main>
        <div class="banner-container">
            <div class="banner-content">
                <div class="countdown">
                    <span id="days">00D</span>
                    <span id="hours">00H</span>
                    <span id="minutes">00M</span>
                    <span id="seconds">00S</span>
                </div>
                <p>
                    Make an impact now for the academic year ahead. Support
                    students, faculty, and researchers with a gift by Columbia’s
                    fiscal year end on Tuesday, June 30
                </p>
            </div>
            <div class="cta-container">
                <a
                    id="cta"
                    class="cta"
                    href="https://www.givenow.columbia.edu/?ac=26CU147587WR&utm_source=CUmagazine&utm_medium=website&utm_campaign=FYE26banner"
                    target="_blank"
                >
                    <span class="cta-text">Give Now</span>
                </a>
                <button id="close">X</button>
            </div>
        </div>
    </main>
</Layout>

<style>
    :root {
        --bg: #1d4f91;
        --btn-bg: #fed302;
        --btn-color: #003373;
    }
    body {
        margin: 0;
        padding: 0;
    }
    .banner-container {
        background-color: var(--bg);
        color: #fff;
        display: flex;
        justify-content: space-between;
        padding: 0 9%;
        width: calc(100% - 18%);
        gap: 14px;
    }
    .banner-container.closed {
        display: none;
    }
    .banner-content {
        display: flex;
        align-items: center;
        gap: 14px;
        flex-shrink: 1;
        min-width: 0;
    }
    .countdown {
        display: flex;
        gap: 6px;
    }
    .countdown span {
        border: 2px solid #6dacde;
        background: #003373;
        padding: 5px 7px;
        font-weight: bold;
    }
    .banner-content p span {
        display: inline-block;
    }
    .cta-container {
        display: flex;
        align-items: center;
        gap: 35px;
        flex-shrink: 0;
    }
    .cta-container .cta {
        background-color: var(--btn-bg);
        color: var(--btn-color);
        padding: 10px 24px;
        font-size: 16px;
        text-decoration: none;
        font-weight: bold;
        font-family: proxima-nova, sans-serif;
        white-space: nowrap;
    }
    #close {
        width: 16px;
        height: 16px;
        border-radius: 50%;
        background: var(--bg);
        border: 1px solid #fff;
        color: #fff;
        font-size: 8px;
        padding-inline: 0;
        padding-top: 2px;
        cursor: pointer;
    }
    @media screen and (max-width: 990px) {
        .banner-container {
            padding: 1em 2em;
            width: calc(100% - 4em);
            flex-direction: column;
            justify-content: unset;
            align-items: center;
            gap: 1em;
        }
        .banner-content {
            flex-direction: column;
        }
        .banner-content p {
            margin: 0;
            text-align: center;
        }
        #close {
            position: absolute;
            top: 1.5em;
            right: 1.5em;
        }
        .cta-container {
            min-width: unset;
        }
    }
</style>

<script>
    const configs: Record<string, { bg: string }> = {
        giving: {
            bg: "#1d4f91",
        },
        alumni: {
            bg: "#1d4f91",
        },
        magazine: {
            bg: "#395ea1",
        },
    };

    const site = new URLSearchParams(window.location.search).get("site") ?? "giving";
    const config = configs[site] ?? configs.giving;

    const root = document.documentElement;
    root.style.setProperty("--bg", config.bg);

    const close = document.getElementById("close") as HTMLElement;
    close.addEventListener("click", () => {
        window.parent.postMessage("banner closed", "*");
    });

    // Anchor the deadline to a fixed UTC offset (ISO 8601) so the countdown
    // ends at the same real-world instant for every visitor, regardless of
    // their browser's timezone. June is Daylight Saving, so Eastern = EDT =
    // UTC-04:00 (in winter it would be EST = UTC-05:00). See AGENTS note.
    var end: Date = new Date("2026-06-30T23:59:00-04:00");

    var _second = 1000;
    var _minute = _second * 60;
    var _hour = _minute * 60;
    var _day = _hour * 24;
    var timer: number;

    function showRemaining() {
        var now: Date = new Date();
        var distance: number = end - now;
        if (distance < 0) {
            clearInterval(timer);
            return;
        }
        var days = Math.floor(distance / _day);
        var hours = Math.floor((distance % _day) / _hour);
        var minutes = Math.floor((distance % _hour) / _minute);
        var seconds = Math.floor((distance % _minute) / _second);

        const daysElement = document.getElementById("days") as HTMLElement;
        const hoursElement = document.getElementById("hours") as HTMLElement;
        const minutesElement = document.getElementById("minutes") as HTMLElement;
        const secondsElement = document.getElementById("seconds") as HTMLElement;

        daysElement.innerHTML = days + "D";
        hoursElement.innerHTML = hours + "H";
        minutesElement.innerHTML = minutes + "M";
        secondsElement.innerHTML = seconds + "S";
    }
    timer = setInterval(showRemaining, 1000);

    function postHeight() {
        window.parent.postMessage(
            { type: "resize", height: document.body.scrollHeight },
            "*"
        );
    }

    const observer = new ResizeObserver(postHeight);
    observer.observe(document.body);
</script>
